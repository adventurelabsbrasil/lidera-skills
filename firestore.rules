rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =====================================================================
    // AUTH HELPERS
    // =====================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasUserRole() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/user_roles/$(request.auth.uid));
    }

    function userRole() {
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data;
    }

    // Legacy fallback: usuários sem documento em user_roles são tratados como
    // "dono inicial" (L0). Mantido durante janela de migração; remover quando
    // todos os user_roles tiverem `level` populado.
    function isLegacyInitialOwner() {
      return isAuthenticated() && !hasUserRole();
    }

    // =====================================================================
    // ACCESS LEVELS (RBAC L0-L3)
    //
    // L0 — Dev/Admin Adventure+Lidera: todos os tenants, qualquer escrita.
    // L1 — Owner do tenant: tudo dentro do tenant, cria L2/L3 do próprio tenant.
    // L2 — Gestor: tudo dentro do tenant, não cria usuários.
    // L3 — Líder de setor: leitura do tenant (UI filtra por setor); sem write
    //      em coleções compartilhadas. Granularidade fina por setor é aplicada
    //      client-side via `user_roles.sectorIds` até evaluations.sectorId ser
    //      denormalizado (follow-up).
    // =====================================================================

    function isL0() {
      // Novo modelo: level == 'L0'. Legado: role == 'master' OU sem doc.
      return isLegacyInitialOwner() ||
             (hasUserRole() && (
               userRole().level == 'L0' ||
               userRole().role == 'master'
             ));
    }

    function isL1Tenant(companyId) {
      // Novo: level == 'L1' e companyId match. Legado: role == 'company'.
      return hasUserRole() && companyId != null && (
               (userRole().level == 'L1' && userRole().companyId == companyId) ||
               (userRole().role == 'company' && userRole().companyId == companyId)
             );
    }

    function isL2Tenant(companyId) {
      return hasUserRole() && companyId != null &&
             userRole().level == 'L2' && userRole().companyId == companyId;
    }

    function isL3Tenant(companyId) {
      return hasUserRole() && companyId != null &&
             userRole().level == 'L3' && userRole().companyId == companyId;
    }

    // L0 OU qualquer nível com acesso ao tenant. Usado para read amplo.
    function canReadTenant(companyId) {
      return isL0() ||
             isL1Tenant(companyId) ||
             isL2Tenant(companyId) ||
             isL3Tenant(companyId);
    }

    // L0/L1/L2 do tenant. Usado para writes em dados de configuração
    // (sectors, roles, criteria, employees, goals).
    function canWriteTenant(companyId) {
      return isL0() ||
             isL1Tenant(companyId) ||
             isL2Tenant(companyId);
    }

    // =====================================================================
    // COMPANIES
    // =====================================================================

    match /companies/{companyId} {
      allow read: if canReadTenant(companyId);
      allow create: if isL0();
      allow update, delete: if isL0();
    }

    // =====================================================================
    // USER ROLES
    //
    // - L0 lê/escreve qualquer.
    // - L1 lê os user_roles do próprio tenant (pra listar sua equipe e criar
    //   L2/L3). Escrita L1 é limitada a docs do mesmo tenant + level L2/L3
    //   (não pode promover/rebaixar pra L0/L1).
    // - L2/L3 leem só o próprio doc.
    // =====================================================================

    function l1CanWriteUserRole(newData) {
      // L1 só cria/edita docs do próprio tenant, e só level L2 ou L3.
      return hasUserRole() &&
             userRole().level == 'L1' &&
             newData.companyId == userRole().companyId &&
             newData.level in ['L2', 'L3'];
    }

    match /user_roles/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        isL0() ||
        (hasUserRole() && userRole().level == 'L1' &&
         resource.data.companyId == userRole().companyId)
      );

      allow create: if isL0() || l1CanWriteUserRole(request.resource.data);

      allow update: if isL0() || (
        l1CanWriteUserRole(request.resource.data) &&
        // Não permite trocar o companyId do doc (defesa contra cross-tenant)
        resource.data.companyId == request.resource.data.companyId
      );

      allow delete: if isL0();
    }

    // =====================================================================
    // TENANT CONFIG (sectors, roles, evaluation_criteria)
    //
    // Dois schemas convivem durante migração:
    //   - `companyId: string` (singular, novo) — doc pertence a 1 tenant.
    //   - `companyIds: string[]` (plural, legado universal) — doc disponível
    //     em múltiplos tenants. SectorsView/RolesView atuais usam esse.
    // Docs sem nenhum dos dois = universais (qualquer auth lê; só L0 escreve).
    //
    // FIX #3: antes qualquer auth lia/escrevia em qualquer tenant. Agora há
    // isolamento real — `canReadTenantConfig` / `canWriteTenantConfig`.
    // =====================================================================

    function canReadTenantConfig(data) {
      return isL0() ||
        // Schema novo: companyId singular
        ('companyId' in data && data.companyId != null &&
          canReadTenant(data.companyId)) ||
        // Schema legado: companyIds plural — user precisa ter companyId no array
        ('companyIds' in data && hasUserRole() &&
          userRole().companyId != null &&
          userRole().companyId in data.companyIds) ||
        // Universal: nem companyId nem companyIds → qualquer autenticado lê
        (!('companyId' in data) && !('companyIds' in data));
    }

    function canWriteTenantConfig(data) {
      return isL0() ||
        // Schema novo: companyId singular
        ('companyId' in data && data.companyId != null &&
          canWriteTenant(data.companyId)) ||
        // Schema legado: companyIds plural — só L1/L2 do tenant pode escrever
        // se seu companyId estiver no array
        ('companyIds' in data && hasUserRole() &&
          userRole().companyId != null &&
          userRole().companyId in data.companyIds &&
          (userRole().level == 'L1' || userRole().level == 'L2' ||
           userRole().role == 'company'));
        // Universal sem nenhum dos campos: só L0 escreve — coberto pela
        // primeira cláusula `isL0()`.
    }

    match /sectors/{sectorId} {
      allow read: if isAuthenticated() && canReadTenantConfig(resource.data);
      allow create: if isAuthenticated() && canWriteTenantConfig(request.resource.data);
      allow update, delete: if isAuthenticated() && canWriteTenantConfig(resource.data);
    }

    match /roles/{roleId} {
      allow read: if isAuthenticated() && canReadTenantConfig(resource.data);
      allow create: if isAuthenticated() && canWriteTenantConfig(request.resource.data);
      allow update, delete: if isAuthenticated() && canWriteTenantConfig(resource.data);
    }

    match /evaluation_criteria/{criteriaId} {
      allow read: if isAuthenticated() && canReadTenantConfig(resource.data);
      allow create: if isAuthenticated() && canWriteTenantConfig(request.resource.data);
      allow update, delete: if isAuthenticated() && canWriteTenantConfig(resource.data);
    }

    // =====================================================================
    // EMPLOYEES, EVALUATIONS, GOALS
    //
    // Read: L0/L1/L2/L3 do tenant (UI filtra por setor para L3).
    // Write: L0/L1/L2 do tenant. L3 read-only no MVP — quando evaluations
    // ganhar `sectorId` denormalizado, libera L3 escrever só no próprio setor.
    // =====================================================================

    match /employees/{employeeId} {
      allow read: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        canReadTenant(resource.data.companyId)
      );
      allow create: if isAuthenticated() && (
        !('companyId' in request.resource.data) ||
        canWriteTenant(request.resource.data.companyId)
      );
      allow update, delete: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        canWriteTenant(resource.data.companyId)
      );
    }

    match /evaluations/{evaluationId} {
      allow read: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        canReadTenant(resource.data.companyId)
      );
      allow create: if isAuthenticated() && (
        !('companyId' in request.resource.data) ||
        canWriteTenant(request.resource.data.companyId)
      );
      allow update, delete: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        canWriteTenant(resource.data.companyId)
      );
    }

    match /performance_goals/{goalId} {
      allow read: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        canReadTenant(resource.data.companyId)
      );
      allow write: if isAuthenticated() && (
        !('companyId' in request.resource.data) ||
        canWriteTenant(request.resource.data.companyId)
      );
    }

    // =====================================================================
    // AUDIT LOGS
    //
    // Read: L0/L1/L2 do tenant. L3 não lê audit log (sensível).
    // Create: qualquer autenticado (toda ação registrada deve gravar).
    // Update/delete: bloqueado — audit log é append-only.
    // =====================================================================

    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (
        !('companyId' in resource.data) ||
        isL0() ||
        isL1Tenant(resource.data.companyId) ||
        isL2Tenant(resource.data.companyId)
      );
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // =====================================================================
    // USERS (coleção legada — manter comportamento atual)
    // =====================================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isL0();
    }

    // =====================================================================
    // DEFAULT DENY
    // =====================================================================

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
